# Although the stream_backlog function is not a EE function, it is dependent on the EE feature change_tracking.

statement ok
DROP DATABASE IF EXISTS test_stream_backlog

statement ok
CREATE DATABASE test_stream_backlog

statement ok
USE test_stream_backlog

statement error 1025
call system$stream_backlog('not_exist')

statement error 1025
select * from stream_backlog('not_exist')

statement ok
create table t(a int)

statement ok
alter table t set options(change_tracking=true)

statement ok
create stream if not exists s on table t

query IIII
select * from stream_backlog('s')
----
0 0 0 0

query IIII
select * from stream_backlog('test_stream_backlog.s')
----
0 0 0 0

query IIII
select * from stream_backlog('default.test_stream_backlog.s')
----
0 0 0 0

query IIII
call system$stream_backlog('s')
----
0 0 0 0

query IIII
call system$stream_backlog('test_stream_backlog.s')
----
0 0 0 0

query IIII
call system$stream_backlog('default.test_stream_backlog.s')
----
0 0 0 0

statement ok
insert into t values(1), (2)

query IIIB
select rows_added, rows_removed, estimated_rows, estimated_bytes > 0 from stream_backlog('s')
----
2 0 2 1

statement ok
create table t_append_delete_insert(a int)

statement ok
insert into t_append_delete_insert values(1), (2)

statement ok
create stream s_append_delete_insert on table t_append_delete_insert append_only = true

statement ok
delete from t_append_delete_insert where a = 1

statement ok
insert into t_append_delete_insert values(3)

query IIIB
select rows_added, rows_removed, estimated_rows, estimated_bytes > 0 from stream_backlog('s_append_delete_insert')
----
1 0 1 1

