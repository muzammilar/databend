statement ok
create table t_standard_merge(a int, b int)

statement ok
insert into t_standard_merge values(1, 10), (2, 20), (3, 30)

statement ok
create table t_merge_source(a int, b int)

statement ok
insert into t_merge_source values(2, 200), (3, 300), (4, 400)

statement ok
create stream s_standard_merge on table t_standard_merge append_only = false

statement ok
merge into t_standard_merge as t using t_merge_source as s on t.a = s.a when matched and t.a = 2 then update set t.b = s.b when matched and t.a = 3 then delete when not matched then insert values(s.a, s.b)

query III
select rows_added, rows_removed, estimated_rows from stream_backlog('s_standard_merge')
----
3 3 4

statement ok
create table t_standard_replace(a int, b int)

statement ok
insert into t_standard_replace values(1, 10), (2, 20)

statement ok
create table t_replace_source(a int, b int)

statement ok
insert into t_replace_source values(2, 200), (3, 300)

statement ok
create stream s_standard_replace on table t_standard_replace append_only = false

statement ok
replace into t_standard_replace on(a) select * from t_replace_source

query III
select rows_added, rows_removed, estimated_rows from stream_backlog('s_standard_replace')
----
3 2 3

