## -------------------------------------------------------
## Vacuum virtual column test
##
## Verifies schema pruning and orphan _vb_v2 file cleanup.
## Uses fs:// storage + list_stage to observe _vb_v2 files on disk.
##
## Other vacuum behaviors (legacy _vb cleanup, detaching legacy block metas)
## are covered by integration tests in
## src/query/service/tests/it/storages/fuse/operations/virtual_columns.rs
## -------------------------------------------------------

statement ok
DROP DATABASE IF EXISTS test_vacuum_virtual_column

statement ok
CREATE DATABASE test_vacuum_virtual_column

statement ok
USE test_vacuum_virtual_column

statement ok
set enable_experimental_virtual_column = 1;

statement ok
set data_retention_time_in_days = 0;

statement ok
CREATE TABLE vacuum_test (id INT, v VARIANT) 'fs:///tmp/test_vacuum_virtual_column/' storage_format = 'parquet' enable_virtual_column = true;

statement ok
CREATE OR REPLACE STAGE vb_stage url = 'fs:///tmp/test_vacuum_virtual_column/';

# Batch 1: rows with fields a, b
statement ok
INSERT INTO vacuum_test VALUES (1, '{"a":1, "b":2}'), (2, '{"a":3, "b":4}'), (3, '{"a":5, "b":6}');

# Batch 2: rows with fields a, b, c, d (c and d are unique to this batch)
statement ok
INSERT INTO vacuum_test VALUES (4, '{"a":7, "b":8, "c":9, "d":10}'), (5, '{"a":11, "b":12, "c":13, "d":14}'), (6, '{"a":15, "b":16, "c":17, "d":18}');

statement ok
REFRESH VIRTUAL COLUMN FOR vacuum_test;

# Schema has 4 fields (a, b, c, d), 2 _vb_v2 files (one per block)
query TTTITT
show virtual columns from vacuum_test;
----
test_vacuum_virtual_column vacuum_test v 3000000000 ['a'] UInt64
test_vacuum_virtual_column vacuum_test v 3000000001 ['b'] UInt64
test_vacuum_virtual_column vacuum_test v 3000000002 ['c'] UInt64
test_vacuum_virtual_column vacuum_test v 3000000003 ['d'] UInt64

query I
select count() from list_stage(location=> '@vb_stage') where name like '%_vb_v2%';
----
2

# Delete batch 2 (the rows with c, d). The block is removed, its _vb_v2 becomes orphan.
statement ok
DELETE FROM vacuum_test WHERE id >= 4;

# Refresh rebuilds _vb_v2 for the rewritten blocks (only a, b remain in data).
# Schema still has 4 fields (refresh merges, doesn't prune).
statement ok
REFRESH VIRTUAL COLUMN FOR vacuum_test;

query TTTITT
show virtual columns from vacuum_test;
----
test_vacuum_virtual_column vacuum_test v 3000000000 ['a'] UInt64
test_vacuum_virtual_column vacuum_test v 3000000001 ['b'] UInt64
test_vacuum_virtual_column vacuum_test v 3000000002 ['c'] UInt64
test_vacuum_virtual_column vacuum_test v 3000000003 ['d'] UInt64

# Purge old snapshots so orphan _vb_v2 files are no longer referenced.
statement ok
select * from fuse_vacuum2('test_vacuum_virtual_column', 'vacuum_test') ignore_result;

# Vacuum prunes unreferenced fields (c, d) and removes orphan _vb_v2 files.
query I
VACUUM VIRTUAL COLUMN FROM vacuum_test;
----
1

# After vacuum: only a and b remain in schema
query TTTITT
show virtual columns from vacuum_test;
----
test_vacuum_virtual_column vacuum_test v 3000000000 ['a'] UInt64
test_vacuum_virtual_column vacuum_test v 3000000001 ['b'] UInt64

# Orphan _vb_v2 file removed, only 1 remains
query I
select count() from list_stage(location=> '@vb_stage') where name like '%_vb_v2%';
----
1

# Data intact
query II
select id, v['a'] from vacuum_test order by id;
----
1 1
2 3
3 5

statement ok
remove @vb_stage;

statement ok
drop stage vb_stage;

statement ok
set enable_experimental_virtual_column = 0;

statement ok
DROP DATABASE test_vacuum_virtual_column
